{
	"ai_models": {
		"anthropic": {
			"api_endpoint": "https://api.anthropic.com/v1/messages",
			"enabled": false,
			"model": "claude-3-5-haiku-20241022"
		},
		"cursor": {
			"api_endpoint": "http://127.0.0.1:8080/v1/chat/completions",
			"api_mode": "local_proxy",
			"enabled": false,
			"model": "composer-2.5"
		},
		"default_provider": "ollama",
		"gemini": {
			"api_endpoint": "https://generativelanguage.googleapis.com/v1beta",
			"enabled": false,
			"model": "gemini-2.0-flash"
		},
		"kimi": {
			"api_endpoint": "https://api.moonshot.ai/v1/chat/completions",
			"enabled": false,
			"model": "kimi-k2.5"
		},
		"lmstudio": {
			"api_endpoint": "http://localhost:1234/v1/chat/completions",
			"enabled": false,
			"model": "local-model"
		},
		"minimax": {
			"api_endpoint": "https://api.minimax.io/v1/chat/completions",
			"enabled": false,
			"model": "MiniMax-M2.5"
		},
		"ollama": {
			"api_endpoint": "http://localhost:11434",
			"enabled": true,
			"model": "llama3.2"
		},
		"openai": {
			"api_endpoint": "https://api.openai.com/v1/chat/completions",
			"enabled": false,
			"model": "gpt-4o-mini"
		},
		"openrouter": {
			"api_endpoint": "https://openrouter.ai/api/v1/chat/completions",
			"enabled": false,
			"model": "openrouter/auto"
		}
	},
	"plugin": {
		"author": "sancheznotdev",
		"description": "Asistente AI integrado en el editor de Godot",
		"name": "Golem-AI",
		"version": "1.3.1"
	},
	"settings": {
		"active_skill": "godot_scene_editing",
		"active_provider": "ollama",
		"active_model": "llama3.2",
		"agent_max_steps": 24,
		"agent_step_extension": 12,
		"context_depth": "intermediate",
		"bootstrap_context_mode": "minimal",
		"enable_agent_loop": true,
		"enable_editor_tools": true,
		"enable_thinking": true,
		"enable_vision": true,
		"harness_base_context_path": "res://addons/ai_assistant_plugin/harness/base_context.md",
		"harness_thinking_path": "res://addons/ai_assistant_plugin/harness/thinking_instructions.md",
		"enable_project_index": true,
		"index_on_startup": true,
		"index_auto_sync": true,
		"index_max_age_hours": 24,
		"enable_semantic_index": true,
		"semantic_index_on_sync": true,
		"embedding_provider": "ollama",
		"embedding_model": "nomic-embed-text",
		"embedding_endpoint": "",
		"semantic_max_chunks": 400,
		"semantic_chunk_size": 1200,
		"semantic_min_score": 0.32,
		"enable_docs_index": true,
		"docs_include_project_md": true,
		"docs_include_godot_classes": true,
		"docs_include_global_classes": true,
		"docs_max_entries": 600,
		"docs_godot_class_limit": 350,
		"docs_max_md_chars": 8000,
		"docs_md_chunk_size": 1400,
		"include_project_context": true,
		"max_response_retries": 3,
		"max_tokens": 4096,
		"ollama_max_num_ctx": 32768,
		"skills_path": "res://addons/ai_assistant_plugin/skills",
		"temperature": 0.7,
		"ui_language": "auto"
	}
}
